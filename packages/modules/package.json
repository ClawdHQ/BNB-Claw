{
  "name": "@bnb-claw/modules",
  "version": "0.1.0",
  "description": "DeFi modules for BNB Claw (Swap, Lend, Stake, Treasury)",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "test": "vitest",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@bnb-claw/core": "workspace:*",
    "ethers": "^6.10.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "tsup": "^8.0.1",
    "vitest": "^1.2.0",
    "typescript": "^5.3.3"
  }
}
