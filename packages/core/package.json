{
  "name": "@bnb-claw/core",
  "version": "0.1.0",
  "description": "Core framework for BNB Claw AI agents",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "test": "vitest",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "openai": "^4.28.0",
    "@anthropic-ai/sdk": "^0.17.0",
    "zod": "^3.22.4",
    "eventemitter3": "^5.0.1",
    "ethers": "^6.10.0"
  },
  "devDependencies": {
    "tsup": "^8.0.1",
    "vitest": "^1.6.1",
    "typescript": "^5.3.3"
  }
}
